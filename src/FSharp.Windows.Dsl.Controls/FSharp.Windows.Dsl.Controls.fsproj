<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFrameworks>net461;net8.0-windows;net9.0-windows;net10.0-windows</TargetFrameworks>
        <UseWPF>true</UseWPF>
        <Description>Generated WPF control wrappers for FSharp.Windows.Dsl</Description>
    </PropertyGroup>
    <ItemGroup>
        <!-- Generated files — depth-prefixed filenames ensure correct compilation order -->
        <Compile Include="Generated/*.generated.fs" />
        <!-- Registration before Elements (AutoOpen in Elements shadows module names) -->
        <Compile Include="Registration.generated.fs" />
        <Compile Include="Elements.generated.fs" />
        <Compile Include="Style.fs" />
        <Compile Include="Build.fs" />
        <Compile Include="Validation.fs" />
    </ItemGroup>
    <ItemGroup>
        <ProjectReference Include="..\FSharp.Windows.Dsl\FSharp.Windows.Dsl.fsproj" />
    </ItemGroup>
</Project>
